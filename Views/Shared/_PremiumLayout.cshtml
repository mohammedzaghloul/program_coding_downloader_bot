@using Microsoft.Extensions.Options
@inject IOptions<DownloaderOptions> DownloaderOptions
@{
    var botUsername = DownloaderOptions.Value.TelegramBotUsername?.Trim().TrimStart('@');
    var botLink = string.IsNullOrWhiteSpace(botUsername) ? null : $"https://t.me/{botUsername}";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Premium Downloader</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.rtl.min.css" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-premium py-3">
            <div class="container">
                <a class="navbar-brand brand-lockup" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><i class="bi bi-cloud-arrow-down"></i></span>
                    <span>
                        <strong>Premium Downloader</strong>
                        <small>بوت + موقع لتنزيل الروابط المباشرة</small>
                    </span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="القائمة">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Home" asp-action="Index">الرئيسية</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Download" asp-action="Index">التحميل</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Home" asp-action="Privacy">الخصوصية</a>
                        </li>
                        @if (!string.IsNullOrWhiteSpace(botLink))
                        {
                            <li class="nav-item mt-3 mt-lg-0">
                                <a class="btn btn-premium py-2 px-4 ms-lg-3" href="@botLink" target="_blank" rel="noreferrer">
                                    <i class="bi bi-telegram ms-2"></i>افتح البوت
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-premium py-4">
        <div class="container text-center">
            <p class="mb-1">© 2026 Premium Downloader</p>
            <p class="mb-0 footer-note">واجهة جاهزة لربط الإعلانات أو روابط الدعم ثم نشرها على أي استضافة ASP.NET.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
